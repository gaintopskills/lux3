---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import ParallaxHeader from '../components/Header/Lacornue.jsx'
const structuredData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://luxuryappliance.repair/la-cornue-appliance-repair/",
  "name": "Luxury Appliance Repair by Zaricci",
  "url": "https://luxuryappliance.repair/la-cornue-appliance-repair/",
  "image": "https://luxuryappliance.repair/zaricci-logo.webp",
  "telephone": "+1-424-499-7788",
  "priceRange": "$$$",
  "description": "Luxury Appliance Repair by Zaricci specializes in La Cornue appliance repair, installation, and maintenance for legendary French ranges and kitchen masterpieces. Our certified technicians deliver white-glove service with artisan care, using genuine La Cornue parts to preserve the craftsmanship, elegance, and performance of your Château, CornuFé, and CornuChef ranges across Los Angeles and surrounding areas.",
  "brand": {
    "@type": "Brand",
    "name": "La Cornue",
    "url": "https://lacornueusa.com/"
  },
  "serviceType": "La Cornue Appliance Repair, Installation, and Maintenance",
  "areaServed": {
