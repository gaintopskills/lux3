---
import MegaMenu from '../components/MegaMenu.jsx';
import Reviews from '../components/Reviews.jsx';
import { Brands } from '../components/Brands.jsx';
import Footer from '../components/Footer.jsx';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import type { BreadcrumbItem } from '../components/Breadcrumbs.astro';

interface Props {
	title?: string;
	description?: string;
	type?: 'website' | 'article';
	structuredData?: object;
	breadcrumbs?: BreadcrumbItem[];
	canonical?: string;
	ogImage?: string;
}

const { 
	title = "Luxury Appliance Repair by ZARICCI",
	description = "Welcome to Luxury Appliance Repair by ZARICCI, your go-to high-end appliance repair company you can trust",
	type = "website",
	structuredData,
	breadcrumbs = [],
	canonical,
	ogImage = "/og-default.webp"
} = Astro.props;

const canonicalURL = canonical
	? new URL(canonical)
	: new URL(Astro.url.pathname, Astro.site ?? 'http://localhost:4321');

const ogImageURL = new URL(ogImage, Astro.site ?? canonicalURL.origin).toString();

const defaultStructuredData = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": title,
	"description": description,
	"url": canonicalURL.toString()
};

const finalStructuredData = structuredData || defaultStructuredData;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=AW-18119819586"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'AW-18119819586');
</script>

